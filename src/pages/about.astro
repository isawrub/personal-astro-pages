---
// src/pages/about.astro
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Import your ported devportfolio components
import Hero from "../components/portfolio/Hero.astro";
import About from "../components/portfolio/About.astro";
import Projects from "../components/portfolio/Projects.astro";
import Experience from "../components/portfolio/Experience.astro";
import Education from "../components/portfolio/Education.astro";

import { portfolioConfig } from "../portfolioConfig";
---

<Layout title={`About | ${portfolioConfig.name}`}>
  <Header activeNav="about" />
  
  {/* Wrap the portfolio in a container that provides devportfolio's layout spacing */}
  <main id="main-content" class="mx-auto max-w-3xl px-4 pb-12 text-foreground">
    {/* Inject devportfolio's required CSS custom properties locally */}
    <style define:vars={{ accentColor: portfolioConfig.accentColor }}>
      :global(.accent-text) {
        color: var(--accentColor);
      }
      :global(.accent-bg) {
        background-color: var(--accentColor);
      }
    </style>

    <div class="space-y-16 py-8">
      <Hero />
      <About />
      <Projects />
      <Experience />
      <Education />
    </div>
  </main>

  <Footer />
</Layout>